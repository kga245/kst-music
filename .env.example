# kst-music — required environment variables
#
# Copy this to `.env.local` for local dev, or add each one via
#   vercel env add <NAME> <preview|production|development>
#
# Values are secrets — do not commit .env.local.

# Replicate API token (https://replicate.com/account/api-tokens).
# Used by /generate to call meta/musicgen. Server-side only.
REPLICATE_API_TOKEN=

# Vercel Blob read/write token. Get from the Vercel dashboard
# (Storage → Blob store → "Connect Project") or via `vercel env pull`
# after you've attached a Blob store to the project. Server-side only.
BLOB_READ_WRITE_TOKEN=

# Optional: override the musicgen variant.
# Allowed: "stereo-melody-large" (default), "stereo-large",
# "melody-large", "large".
# MUSICGEN_VARIANT=stereo-melody-large
