# kst-music — required environment variables
#
# Copy this to `.env.local` for local dev, or add each one via
#   vercel env add <NAME> <preview|production|development>
#
# Values are secrets — do not commit .env.local.

# Replicate API token (https://replicate.com/account/api-tokens).
# Used by /generate to call meta/musicgen. Server-side only.
REPLICATE_API_TOKEN=

# Vercel Blob read/write token. Get from the Vercel dashboard
# (Storage → Blob store → "Connect Project") or via `vercel env pull`
# after you've attached a Blob store to the project. Server-side only.
BLOB_READ_WRITE_TOKEN=

# Optional: override the musicgen variant.
# Allowed: "stereo-melody-large" (default), "stereo-large",
# "melody-large", "large".
# MUSICGEN_VARIANT=stereo-melody-large

# Supabase (KST-5 waitlist + invite codes).
# Grab via `supabase projects api-keys --project-ref <ref>` or the dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated allowlist of admin emails (magic-link auth).
ADMIN_EMAILS=kga245@gmail.com

# Public origin used to build the magic-link redirect. In local dev this is
# http://localhost:3000. In preview/prod, Vercel injects VERCEL_URL — prefer
# setting this to the canonical production origin once it's known.
NEXT_PUBLIC_SITE_URL=

# Optional: URL of the pre-generated demo audio clip shown on the landing
# page. Produced once via /generate and then pasted here.
DEMO_AUDIO_URL=
